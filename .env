# MCP 服务配置
# 支持的 transport 类型：stdio（本地进程）、streamable-http（HTTP 流）
# 也可以配置真实的cls mcp服务： https://cloud.tencent.com/developer/mcp/server/11710
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# Langfuse 可观测性平台配置（可选）
